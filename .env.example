# Copy this file to `.env.local` and fill in the real value.
# `.env.local` is the ONLY place for secrets — never hard-code keys in components or lib.

OPENAI_API_KEY=

# Optional — override the advisor model (default in backend/models.ts):
# ADVISOR_MODEL=gpt-4o-mini

# ── Supabase (A안: supabase-js) ──
# 프로젝트 URL — 비밀 아님
NEXT_PUBLIC_SUPABASE_URL=
# 서버 전용 비밀 키 (RLS 우회, 권장). Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=
# 서비스 롤 키가 없으면 anon 키로도 동작 (테이블 RLS off 필요):
# SUPABASE_ANON_KEY=

# ── 기상청 단기예보 조회서비스 (공공데이터포털) ──
# data.go.kr → "기상청_단기예보 조회서비스" 활용신청 → 일반 인증키(Decoding)
KMA_SERVICE_KEY=

# ── aisstream.io (실시간 AIS 선박 데이터, WebSocket) ──
# https://aisstream.io/authenticate 에서 무료 발급.
# 웹앱이 아니라 backend/ais/ingest-aisstream.ts 수집 스크립트(npm run ingest:ais)가 사용한다.
AISSTREAM_API_KEY=

# ── 해양수산부_선박운항정보 (Port-MIS 입출항 신고, 공공데이터포털) ──
# data.go.kr → "해양수산부_선박운항정보" 활용신청(기관 승인 필요) → 일반 인증키(Decoding)
# 오퍼레이션: apis.data.go.kr/1192000/VsslEtrynd5/Info5 — 항구·조회기간·입출항구분으로 조회,
# 응답에 직전출항항/다음기항지·선석명이 포함돼 AIS보다 정확하게 "부산 입출항"을 확인할 수 있다.
# 웹앱이 아니라 backend/portmis/run-enrich.ts 스크립트(npm run enrich:portmis)가 사용한다.
MOF_SHIP_OPERATION_KEY=

# ── 지도 배경 타일 ──
# 타일은 브라우저가 직접 받으므로 NEXT_PUBLIC_ 접두사가 필요하고, 키가 URL에 노출된다(타일 서비스 정상).
#
# 지도 타입은 화면 우하단 "지도 타입" 드롭다운에서 골라 쓴다(선택값은 브라우저에 저장).
# 아래 env는 "초기 기본값"과 키가 필요한 배경(VWorld·ENC)만 설정한다.
#
# [권장] VWorld(국가공간정보포털, 무료) — vworld.kr → 인증키 발급 신청 시 "사용 도메인"에
#   localhost 와 배포 도메인(예: bug-ai-hackerton.vercel.app)을 등록해야 타일이 나온다.
#   키를 넣으면 "기본/위성" 배경이 국토부 VWorld 타일로 승격된다(위성엔 지명 라벨 오버레이).
NEXT_PUBLIC_VWORLD_KEY=
# 첫 진입 시 선택될 배경: base(기본) | light(라이트) | dark(다크) | satellite(위성) | enc(전자해도)
NEXT_PUBLIC_VWORLD_LAYER=base
#
# [ENC 전자해도] 국립해양조사원(khoa.go.kr) 전자해도 타일 URL 템플릿.
#   키·도메인 등록이 필요한 서비스라 완성된 URL을 직접 넣어야 "ENC 전자해도" 항목이 활성화된다.
#   예: NEXT_PUBLIC_ENC_TILE_URL=https://.../{z}/{y}/{x}.png
NEXT_PUBLIC_ENC_TILE_URL=

# 해양수산부 AIS API 서비스키 (공공데이터포털)
MOF_AIS_API_KEY=
# 해양수산부 AIS 통계 WFS 요청 domain — 인증키 발급 시 등록한 호스트(스킴/슬래시 없이)
MOF_AIS_DOMAIN=
